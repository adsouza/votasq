rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /problems/{problemId} {
      allow read: if true;
      allow create: if
        request.resource.data.keys().hasAll(['description', 'votes', 'solved', 'version', 'geoscope'])
        && request.resource.data.description is string
        && request.resource.data.description.size() > 0
        && request.resource.data.description.size() <= 80
        && request.resource.data.geoscope is string
        && request.resource.data.geoscope.size() > 0
        && request.resource.data.geoscope.size() <= 72
        && request.resource.data.votes is int
        && request.resource.data.votes == 1
        && request.resource.data.solved is bool
        && request.resource.data.solved == false
        && request.resource.data.version is int
        && request.resource.data.version == 1;
      allow update: if
        // Vote-only update (auth required, votes +1, version unchanged)
        (
          request.auth != null
          && request.resource.data.votes == resource.data.votes + 1
          && request.resource.data.version == resource.data.version
        )
        ||
        // Full problem update
        (
          request.resource.data.description is string
          && request.resource.data.description.size() > 0
          && request.resource.data.description.size() <= 80
          && request.resource.data.geoscope is string
          && request.resource.data.geoscope.size() > 0
          && request.resource.data.geoscope.size() <= 72
          && (request.resource.data.geoscope == resource.data.geoscope
              || (request.auth != null && request.auth.uid == resource.data.ownerId))
          && request.resource.data.votes is int
          && request.resource.data.votes >= 0
          && request.resource.data.solved is bool
          && request.resource.data.version is int
          && request.resource.data.version > resource.data.version
        );

      match /versions/{versionId} {
        allow read: if true;
        allow create: if
          request.resource.data.keys().hasAll(['description', 'version', 'archivedAt'])
          && request.resource.data.description is string
          && request.resource.data.version is int
          && request.resource.data.archivedAt is timestamp;
      }

      match /voters/{voterId} {
        allow read: if true;
        allow create: if
          request.auth != null
          && request.auth.uid == voterId
          && request.resource.data.keys().hasAll(['uid', 'votes'])
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.votes is int
          && request.resource.data.votes == 1;
        allow update: if
          request.auth != null
          && request.auth.uid == voterId
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.votes is int
          && request.resource.data.votes > resource.data.votes;
      }

      match /translations/{langCode} {
        allow read: if true;
        allow create: if
          request.resource.data.keys().hasAll(['description'])
          && request.resource.data.description is string
          && request.resource.data.description.size() > 0;
        allow delete: if true;
      }
    }

    match /geoscopes/{geoscopeId} {
      allow read: if true;
    }

    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if
        request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasAll(['uid', 'votes', 'lastActiveAt'])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.votes is int
        && request.resource.data.votes == 3 // Must match initialVoteBudget
        && request.resource.data.lastActiveAt is timestamp;
      allow update: if
        request.auth != null
        && request.auth.uid == userId
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.votes is int
        && request.resource.data.votes == resource.data.votes - 1
        && request.resource.data.votes >= 0;
    }

    match /feedback/{feedbackId} {
      allow create: if
        request.auth != null
        && request.resource.data.keys().hasAll(['text', 'screenshotPath', 'userId', 'submittedAt'])
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.screenshotPath is string
        && request.resource.data.userId is string
        && request.resource.data.userId == request.auth.uid;
    }
  }
}
